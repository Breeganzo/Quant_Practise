# Supabase Settings -> API/Data API -> URL (Project URL in some UIs)
# If URL is hidden, derive it from dashboard path /project/PROJECT_REF/... as:
# https://PROJECT_REF.supabase.co
VITE_SUPABASE_URL=

# Supabase Settings -> API -> API Keys -> Publishable key
# Never use the secret key (or legacy service_role key) in frontend env files.
VITE_SUPABASE_ANON_KEY=

# Public repository URL used in app links
VITE_REPO_URL=https://github.com/Breeganzo/Quant_Practise
